<templateSet group="cztctl">

  <!-- ==================== 顶层结构 ==================== -->

  <template name="syntax" value="syntax = &quot;v1&quot;" description="syntax 版本声明" toReformat="false" toShortenFQNames="false">
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="info" value="info (&#10;    title: &quot;$TITLE$&quot;&#10;    desc: &quot;$DESC$&quot;&#10;    version: &quot;$VERSION$&quot;&#10;)" description="info 元信息块" toReformat="false" toShortenFQNames="false">
    <variable name="TITLE" expression="" defaultValue="&quot;服务名称&quot;" alwaysStopAt="true"/>
    <variable name="DESC" expression="" defaultValue="&quot;服务描述&quot;" alwaysStopAt="true"/>
    <variable name="VERSION" expression="" defaultValue="&quot;1.0&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="import" value="import &quot;$FILE$&quot;" description="import 单文件导入" toReformat="false" toShortenFQNames="false">
    <variable name="FILE" expression="" defaultValue="&quot;common.cron&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <!-- ==================== type ==================== -->

  <template name="type" value="type $NAME$ {&#10;    $FIELD$ $TYPE$ `json:&quot;$TAG$&quot;`&#10;}" description="type 结构体声明" toReformat="false" toShortenFQNames="false">
    <variable name="NAME" expression="" defaultValue="&quot;Req&quot;" alwaysStopAt="true"/>
    <variable name="FIELD" expression="" defaultValue="&quot;Id&quot;" alwaysStopAt="true"/>
    <variable name="TYPE" expression="" defaultValue="&quot;int64&quot;" alwaysStopAt="true"/>
    <variable name="TAG" expression="" defaultValue="&quot;id&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="typeg" value="type (&#10;    $NAME$ {&#10;        $FIELD$ $TYPE$ `json:&quot;$TAG$&quot;`&#10;    }&#10;)" description="type 分组结构体声明" toReformat="false" toShortenFQNames="false">
    <variable name="NAME" expression="" defaultValue="&quot;Req&quot;" alwaysStopAt="true"/>
    <variable name="FIELD" expression="" defaultValue="&quot;Id&quot;" alwaysStopAt="true"/>
    <variable name="TYPE" expression="" defaultValue="&quot;int64&quot;" alwaysStopAt="true"/>
    <variable name="TAG" expression="" defaultValue="&quot;id&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <!-- ==================== @server ==================== -->

  <template name="server" value="@server (&#10;    group: $GROUP$&#10;)" description="@server 注解块" toReformat="false" toShortenFQNames="false">
    <variable name="GROUP" expression="" defaultValue="&quot;default&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="serverfull" value="@server (&#10;    tags: &quot;$TAGS$&quot;&#10;    summary: &quot;$SUMMARY$&quot;&#10;    group: $GROUP$&#10;    middleware: $MIDDLEWARE$&#10;)" description="@server 完整注解块" toReformat="false" toShortenFQNames="false">
    <variable name="TAGS" expression="" defaultValue="&quot;标签&quot;" alwaysStopAt="true"/>
    <variable name="SUMMARY" expression="" defaultValue="&quot;摘要&quot;" alwaysStopAt="true"/>
    <variable name="GROUP" expression="" defaultValue="&quot;default&quot;" alwaysStopAt="true"/>
    <variable name="MIDDLEWARE" expression="" defaultValue="&quot;LogMiddleware&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <!-- ==================== service ==================== -->

  <template name="service" value="service $NAME$ {&#10;    $END$&#10;}" description="service 服务块" toReformat="false" toShortenFQNames="false">
    <variable name="NAME" expression="" defaultValue="&quot;app-cron&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <!-- ==================== service 内部注解 ==================== -->

  <template name="@doc" value="@doc &quot;$DOC$&quot;" description="@doc 字符串文档注解" toReformat="false" toShortenFQNames="false">
    <variable name="DOC" expression="" defaultValue="&quot;任务描述&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="@dockv" value="@doc(&#10;    summary: &quot;$SUMMARY$&quot;&#10;    description: &quot;$DESC$&quot;&#10;)" description="@doc KV 文档注解" toReformat="false" toShortenFQNames="false">
    <variable name="SUMMARY" expression="" defaultValue="&quot;摘要&quot;" alwaysStopAt="true"/>
    <variable name="DESC" expression="" defaultValue="&quot;详细描述&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="@handler" value="@handler $NAME$" description="@handler 处理器名称" toReformat="false" toShortenFQNames="false">
    <variable name="NAME" expression="" defaultValue="&quot;HandlerName&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="@cron" value="@cron &quot;$EXPR$&quot;" description="@cron 定时表达式" toReformat="false" toShortenFQNames="false">
    <variable name="EXPR" expression="" defaultValue="&quot;*/5 * * * *&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="@cronRetry" value="@cronRetry $N$" description="@cronRetry 重试次数" toReformat="false" toShortenFQNames="false">
    <variable name="N" expression="" defaultValue="&quot;3&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <!-- ==================== 组合模板 ==================== -->

  <template name="crontask" value="@doc &quot;$DOC$&quot;&#10;    @cron &quot;$EXPR$&quot;&#10;    @cronRetry $RETRY$&#10;    @handler $HANDLER$&#10;    $TASK$($REQ$)" description="完整的内部定时任务" toReformat="false" toShortenFQNames="false">
    <variable name="DOC" expression="" defaultValue="&quot;任务描述&quot;" alwaysStopAt="true"/>
    <variable name="EXPR" expression="" defaultValue="&quot;*/5 * * * *&quot;" alwaysStopAt="true"/>
    <variable name="RETRY" expression="" defaultValue="&quot;3&quot;" alwaysStopAt="true"/>
    <variable name="HANDLER" expression="" defaultValue="&quot;MyJob&quot;" alwaysStopAt="true"/>
    <variable name="TASK" expression="" defaultValue="&quot;MyTask&quot;" alwaysStopAt="true"/>
    <variable name="REQ" expression="" defaultValue="&quot;Req&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="exttask" value="@doc &quot;$DOC$&quot;&#10;    @handler $HANDLER$&#10;    $TASK$($REQ$)" description="外部触发任务（无 @cron）" toReformat="false" toShortenFQNames="false">
    <variable name="DOC" expression="" defaultValue="&quot;任务描述&quot;" alwaysStopAt="true"/>
    <variable name="HANDLER" expression="" defaultValue="&quot;MyJob&quot;" alwaysStopAt="true"/>
    <variable name="TASK" expression="" defaultValue="&quot;MyTask&quot;" alwaysStopAt="true"/>
    <variable name="REQ" expression="" defaultValue="&quot;Req&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="consumer" value="@doc &quot;$DOC$&quot;&#10;    @handler $HANDLER$&#10;    $QUEUE$($MSG$)" description="RabbitMQ 消费者" toReformat="false" toShortenFQNames="false">
    <variable name="DOC" expression="" defaultValue="&quot;事件描述&quot;" alwaysStopAt="true"/>
    <variable name="HANDLER" expression="" defaultValue="&quot;MyConsumer&quot;" alwaysStopAt="true"/>
    <variable name="QUEUE" expression="" defaultValue="&quot;order.created&quot;" alwaysStopAt="true"/>
    <variable name="MSG" expression="" defaultValue="&quot;EventMsg&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <!-- ==================== 完整文件模板 ==================== -->

  <template name="cronfile" value="syntax = &quot;v1&quot;&#10;&#10;info (&#10;    title: &quot;$TITLE$&quot;&#10;    desc: &quot;$DESC$&quot;&#10;    version: &quot;1.0&quot;&#10;)&#10;&#10;type (&#10;    $REQ_NAME$ {&#10;        $FIELD$ $TYPE$ `json:&quot;$TAG$&quot;`&#10;    }&#10;)&#10;&#10;@server (&#10;    group: $GROUP$&#10;)&#10;service $SERVICE$ {&#10;    @doc &quot;$DOC$&quot;&#10;    @cron &quot;$EXPR$&quot;&#10;    @handler $HANDLER$&#10;    $TASK$($REQ_NAME$)&#10;}" description=".cron 完整文件模板" toReformat="false" toShortenFQNames="false">
    <variable name="TITLE" expression="" defaultValue="&quot;定时任务服务&quot;" alwaysStopAt="true"/>
    <variable name="DESC" expression="" defaultValue="&quot;服务描述&quot;" alwaysStopAt="true"/>
    <variable name="REQ_NAME" expression="" defaultValue="&quot;TaskReq&quot;" alwaysStopAt="true"/>
    <variable name="FIELD" expression="" defaultValue="&quot;Id&quot;" alwaysStopAt="true"/>
    <variable name="TYPE" expression="" defaultValue="&quot;int64&quot;" alwaysStopAt="true"/>
    <variable name="TAG" expression="" defaultValue="&quot;id&quot;" alwaysStopAt="true"/>
    <variable name="GROUP" expression="" defaultValue="&quot;default&quot;" alwaysStopAt="true"/>
    <variable name="SERVICE" expression="" defaultValue="&quot;app-cron&quot;" alwaysStopAt="true"/>
    <variable name="DOC" expression="" defaultValue="&quot;任务描述&quot;" alwaysStopAt="true"/>
    <variable name="EXPR" expression="" defaultValue="&quot;*/5 * * * *&quot;" alwaysStopAt="true"/>
    <variable name="HANDLER" expression="" defaultValue="&quot;MyJob&quot;" alwaysStopAt="true"/>
    <variable name="TASK" expression="" defaultValue="&quot;MyTask&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

  <template name="mqfile" value="syntax = &quot;v1&quot;&#10;&#10;info (&#10;    title: &quot;$TITLE$&quot;&#10;    desc: &quot;$DESC$&quot;&#10;    version: &quot;1.0&quot;&#10;)&#10;&#10;type (&#10;    $MSG_NAME$ {&#10;        $FIELD$ $TYPE$ `json:&quot;$TAG$&quot;`&#10;    }&#10;)&#10;&#10;@server (&#10;    group: $GROUP$&#10;)&#10;service $SERVICE$ {&#10;    @doc &quot;$DOC$&quot;&#10;    @handler $HANDLER$&#10;    $QUEUE$($MSG_NAME$)&#10;}" description=".rabbitmq 完整文件模板" toReformat="false" toShortenFQNames="false">
    <variable name="TITLE" expression="" defaultValue="&quot;消息队列服务&quot;" alwaysStopAt="true"/>
    <variable name="DESC" expression="" defaultValue="&quot;服务描述&quot;" alwaysStopAt="true"/>
    <variable name="MSG_NAME" expression="" defaultValue="&quot;EventMsg&quot;" alwaysStopAt="true"/>
    <variable name="FIELD" expression="" defaultValue="&quot;Id&quot;" alwaysStopAt="true"/>
    <variable name="TYPE" expression="" defaultValue="&quot;int64&quot;" alwaysStopAt="true"/>
    <variable name="TAG" expression="" defaultValue="&quot;id&quot;" alwaysStopAt="true"/>
    <variable name="GROUP" expression="" defaultValue="&quot;default&quot;" alwaysStopAt="true"/>
    <variable name="SERVICE" expression="" defaultValue="&quot;app-mq&quot;" alwaysStopAt="true"/>
    <variable name="DOC" expression="" defaultValue="&quot;事件描述&quot;" alwaysStopAt="true"/>
    <variable name="HANDLER" expression="" defaultValue="&quot;MyConsumer&quot;" alwaysStopAt="true"/>
    <variable name="QUEUE" expression="" defaultValue="&quot;order.created&quot;" alwaysStopAt="true"/>
    <context>
      <option name="OTHER" value="true"/>
    </context>
  </template>

</templateSet>
